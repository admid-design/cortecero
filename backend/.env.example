DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cortecero
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=720
CORS_ORIGINS=http://localhost:3000

# Google Route Optimization API (E.2 — dejar vacío para usar mock en E.1/dev/tests)
# Autenticación vía Application Default Credentials (ADC) o service account JSON.
# Ver: https://cloud.google.com/route-optimization/docs/authentication
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
GOOGLE_ROUTE_OPTIMIZATION_PROJECT_ID=
GOOGLE_ROUTE_OPTIMIZATION_LOCATION=global
GOOGLE_ROUTE_OPTIMIZATION_TIMEOUT_SECONDS=30

# Cloudflare R2 — Proof of delivery photos (R8-POD-FOTO)
# Dejar vacíos en dev/tests (los tests mockean R2 completamente).
# R2_ACCOUNT_ID=<account_id>
# R2_ACCESS_KEY_ID=<access_key>
# R2_SECRET_ACCESS_KEY=<secret_key>
# R2_BUCKET_NAME=cortecero-pod-photos
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Coordenadas del depósito de salida del vehículo (WGS-84)
ROUTE_OPTIMIZATION_DEPOT_LAT=39.5696
ROUTE_OPTIMIZATION_DEPOT_LNG=2.6502
